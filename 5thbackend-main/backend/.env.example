MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/cryptotracker?retryWrites=true&w=majority
PORT=5001
JWT_SECRET=replace_with_a_long_random_secret

# Firebase Admin service account, option A
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace_with_service_account_private_key\n-----END PRIVATE KEY-----\n"

# Firebase Admin service account, option B
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your_project_id"}
